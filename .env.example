# =========================================================
# Variaveis de Ambiente - Gestao de Candidatos AP
# Copie este arquivo para .env e preencha os valores reais.
# Nunca versione o .env real no Git.
# =========================================================

# Chave secreta do Flask (troque por uma string aleatoria longa)
SECRET_KEY=troque-por-uma-chave-secreta-bem-longa

# Banco de dados Postgres
# Local:  postgresql+psycopg2://usuario:senha@localhost:5432/gestao_candidatos
# Render: valor do Internal Database URL
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/gestao_candidatos

# Credenciais do Converts (usadas pelo modulo de integracao)
CONVERTS_BASE_URL=https://app.converts.com.br
CONVERTS_LOGIN=seu_login_converts
CONVERTS_SENHA=sua_senha_converts

# Usuario administrador inicial (criado pelo comando 'flask seed')
ADMIN_EMAIL=admin@empresa.com
ADMIN_PASSWORD=troque-essa-senha
ADMIN_NAME=Administrador

# Configuracoes do scheduler
ENABLE_SCHEDULER=true
SYNC_HOUR=23
SYNC_MINUTE=30
TZ=America/Sao_Paulo

# Flask env
FLASK_ENV=production
